#!/bin/bash

count() {
  awk '
    { counts[$0]++ }
    END { for(c in counts) { printf "%6d %s\n", counts[c], c } }
  ' "$@" | sort -n
}

sum() {
  awk '{sum+=$1} END {print sum}' "$@"
}

cumsum() {
  awk '{sum+=$1; print sum}' "$@"
}

diff() {
  awk 'NR > 1 { print $1-prev } { prev=$1 }' "$@"
}

uniq() {
  awk '!seen[$0]++' "$@"
}

# -------------------------------------------------

f="$1"; shift

if test "$f" == "--list"; then
  declare -F | sort | awk '{print $3}'
  exit
fi

if ! declare -f "$f" >/dev/null; then
  printf "Usage: enum {"
  enum --list | awk '{printf "%s%s", (NR == 1 ? "" : "|"), $1}'
  printf "} [file...]\n" >&2
  exit 1
fi

$f "$@"

