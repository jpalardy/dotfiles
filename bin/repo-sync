#!/bin/bash

confirm() {
  local msg=$1
  while true; do
    read -p "$msg (Y/n) " -r
    case $REPLY in
      Y | y | "")
        return 0
        ;;
      N | n)
        return 1
        ;;
    esac
  done
}

# -------------------------------------------------

if [ -z "$TMUX" ]; then
  tmux new-session "$0"
  exit
fi

if test -n "$1"; then
  git fetch --prune
  git status --short
  if [ -n "$(git status --porcelain)" ]; then
    exit 1
  fi
  if [ "$(git rev-parse HEAD)" != "$(git rev-parse "@{u}")" ]; then
    echo
    if confirm "git merge --ff-only?"; then
      git merge --ff-only
    fi
    exit 1
  fi
  exit
fi

for repo in $REPOS; do
  printf "%s\t%s\t%s\n" "$repo" "clear; repo-sync .; and exit" "$(basename "$repo")"
done | tmux.each

