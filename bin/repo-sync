#!/bin/bash

# start tmux if not already inside tmux
if [ -z "$TMUX" ]; then
  tmux new-session -d
  tmux send-keys "repo-sync" Enter
  tmux attach-session
  exit
fi

sync() {
  git fetch --prune
  git status --short
}

generate_commands() {
  local prev=""
  for repo in $REPOS; do
    if [ -n "$prev" ]; then
      echo
      echo "tmux new-window"
    fi
    echo "tmux send-keys 'clear; cd \"$repo\"; and repo-sync .; and exit' C-m"
    prev="$repo"
  done
}

if [ -z "$1" ]; then
  generate_commands | bash
  exit
fi

cd "$1" || exit 1
sync
if [ -n "$(git status --porcelain)" ] || [ "$(git rev-parse HEAD)" != "$(git rev-parse "@{u}")" ]; then
  exit 1
fi

