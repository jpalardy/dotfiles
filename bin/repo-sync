#!/bin/bash

if [ -z "$TMUX" ]; then
  tmux new-session "$0"
  exit
fi

if test -n "$1"; then
  git fetch --prune
  git status --short
  if [ -n "$(git status --porcelain)" ] || [ "$(git rev-parse HEAD)" != "$(git rev-parse "@{u}")" ]; then
    exit 1
  fi
  exit
fi

for repo in $REPOS; do
  printf "%s\t%s\t%s\n" "$repo" "clear; repo-sync .; and exit" "$(basename "$repo")"
done | tmux.map

