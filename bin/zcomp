#!/bin/bash

report() {
  printf "%s-%d %d\n" "$1" "$2" "$($1 -"$2" -c - < "$3" | wc -c)"
}
export -f report

filter_exists() {
  for cmd in "$@"; do
    test "$(command -v "$cmd")" && echo "$cmd"
  done
}

(
  printf "original %d\n" "$(wc -c < "$@")"
  # shellcheck disable=SC2046
  parallel -k report ::: $(filter_exists gzip bzip2 xz zstd) ::: 1 5 9 ::: "$@"
) | awk '
  NR == 1 {original=$2}
  {printf "%12d %5.1f%% %8s\n", $2, $NF/original*100, $1}
'

