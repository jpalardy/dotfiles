#!/bin/bash

report() {
  printf "%s-%d %d\n" "$1" "$2" "$($1 -"$2" -c - < "$3" | wc -c)"
}
export -f report

utils=""
for util in gzip bzip2 xz zstd; do
  if test "$(command -v $util)"; then
    utils="$utils $util"
  fi
done

(
  printf "original %d\n" "$(wc -c < "$@")"
  # shellcheck disable=SC2086
  parallel report ::: $utils ::: 1 5 9 ::: "$@"
) | awk '
  NR == 1 {original=$2}
  {printf "%12d %5.1f%% %8s\n", $2, $NF/original*100, $1}
'

